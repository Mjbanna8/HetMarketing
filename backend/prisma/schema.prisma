generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  mobile       String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)
  failedLogins Int      @default(0)
  lockedUntil  DateTime?
  isVerified   Boolean  @default(false)
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]

  @@map("users")
}

model Admin {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  role            UserRole @default(ADMIN)
  twoFactorSecret String?
  mustChangePassword Boolean @default(true)
  lastLogin       DateTime?
  createdAt       DateTime @default(now())

  @@map("admins")
}

model Category {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  iconUrl      String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  products     Product[]

  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String
  price         Float
  originalPrice Float?
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  status        ProductStatus @default(ACTIVE)
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  tags          String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  images        ProductImage[]
  orders        Order[]

  @@index([categoryId])
  @@index([status])
  @@index([isDeleted])
  @@map("products")
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  cdnPublicId  String
  displayOrder Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model Order {
  id                 String      @id @default(cuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id])
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  quantity           Int
  unitPrice          Float
  totalPrice         Float
  deliveryAddress    String
  customerNote       String?
  status             OrderStatus @default(PENDING)
  whatsappNumberUsed String
  createdAt          DateTime    @default(now())

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
